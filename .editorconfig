# Omnivra AI Company OS â€” editor configuration
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2
max_line_length = 100

# Python â€” PEP 8, 4 spaces, longer lines allowed (matches ruff/black default 88-100)
[*.py]
indent_size = 4
max_line_length = 100

# TypeScript / JavaScript / JSON / CSS / Markdown â€” 2 spaces
[*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc,css,scss,html}]
indent_size = 2

# Markdown â€” do not trim trailing whitespace (two-space line breaks are meaningful)
[*.md]
trim_trailing_whitespace = false
indent_size = 2

# YAML
[*.{yml,yaml}]
indent_size = 2

# Makefiles require tabs
[Makefile]
indent_style = tab

# Windows PowerShell scripts use CRLF
[*.ps1]
end_of_line = crlf
indent_size = 4

# Lockfiles / generated â€” leave alone
[{package-lock.json,pnpm-lock.yaml,yarn.lock,poetry.lock}]
indent_style = unset
indent_size = unset
trim_trailing_whitespace = false
insert_final_newline = unset
