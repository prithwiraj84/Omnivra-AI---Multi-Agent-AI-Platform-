# ===========================================================================
# Omnivra AI Company OS - Backend environment template
# Copy to backend/.env and fill in real values. NEVER commit backend/.env.
# ===========================================================================

# --- App / runtime ---
APP_NAME="Omnivra AI Company OS"
APP_ENV=development                 # development | staging | production
DEBUG=true
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO                      # DEBUG | INFO | WARNING | ERROR
LOG_JSON=false                      # true -> structured JSON logs (prod)

# CORS: comma-separated origins the Vite frontend is served from.
CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"

# Absolute or relative path to the AI artifact sandbox. Agents may ONLY write here.
WORKSPACE_ROOT=../workspace

# --- LLM / Media providers ---
# Google AI Studio (Gemini 2.5 Flash) - CEO/Manager, UI/UX Designer
GOOGLE_AI_STUDIO_API_KEY=

# OpenRouter (OpenAI-compatible) - Architect, DB/FE/BE/API Eng, SecOps, Social, Docs, Recovery
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=https://omnivra.local     # sent as HTTP-Referer (OpenRouter attribution)
OPENROUTER_APP_NAME=Omnivra AI Company OS      # sent as X-Title

# Groq (OpenAI-compatible + Whisper/Orpheus) - QA, SEO, Reel, STT, TTS
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Hugging Face - Image Generation (FLUX.1-dev)
HUGGINGFACE_API_KEY=
HUGGINGFACE_INFERENCE_ENDPOINT=https://api-inference.huggingface.co

# --- Supabase Cloud (Postgres + pgvector + Storage + Realtime) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=                  # browser-safe; used by frontend, mirrored here for parity
SUPABASE_SERVICE_ROLE_KEY=          # SERVER ONLY. Never expose to the frontend.
SUPABASE_DB_PASSWORD=               # for direct asyncpg / langgraph postgres checkpointer (Phase 3)
SUPABASE_STORAGE_BUCKET=omnivra-artifacts
# Direct Postgres DSN (for langgraph-checkpoint-postgres in Phase 3)
SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# --- Redis / Upstash (queue + ephemeral run state) ---
REDIS_URL=redis://localhost:6379/0            # or rediss://default:[TOKEN]@[HOST].upstash.io:6379

# --- Orchestration safety ---
MAX_RECURSION=3                     # kill switch: recursion_count > MAX_RECURSION -> FAILED
PROVIDER_TIMEOUT_SECONDS=60
PROVIDER_MAX_RETRIES=5              # tenacity attempts on 429 / timeout / transient

# --- Security ---
API_SECRET_KEY=change-me-in-prod    # signs internal tokens / approval resume tokens
