# ===========================================================================
# Omnivra AI Company OS - Backend environment template
# Copy to backend/.env and fill in real values. NEVER commit backend/.env.
# ===========================================================================

# --- App / runtime ---
APP_NAME="Omnivra AI Company OS"
APP_ENV=development                 # development | staging | production
DEBUG=true
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO                      # DEBUG | INFO | WARNING | ERROR
LOG_JSON=false                      # true -> structured JSON logs (prod)

# CORS: comma-separated origins the Vite frontend is served from.
CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"

# Absolute or relative path to the AI artifact sandbox. Agents may ONLY write here.
WORKSPACE_ROOT=../workspace

# --- LLM / Media providers ---
# TIP: every *_API_KEY below accepts a POOL of keys — comma-separated, e.g.
#   GROQ_API_KEY=key_one,key_two,key_three
# The provider rotates across them on rate limits (429), so several free-tier keys behave like
# one larger quota with automatic failover. Additionally, a TEXT agent whose provider is fully
# exhausted automatically falls back to another configured provider (Groq <-> Google).

# Google AI Studio (Gemini) - CEO/Manager, Architect, UI/UX, API, QA, SecOps, Social, Docs
GOOGLE_AI_STUDIO_API_KEY=

# OpenRouter (OpenAI-compatible) - Architect, DB/FE/BE/API Eng, SecOps, Social, Docs, Recovery, System-Ops.
# The free tier shares ~50 requests/day PER ACCOUNT across all :free models, so POOL several keys here
# (comma-separated) for a full multi-agent run. If OpenRouter is still exhausted, these agents auto-fall
# back to Groq then Gemini, so a run never stalls.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=https://omnivra.local     # sent as HTTP-Referer (OpenRouter attribution)
OPENROUTER_APP_NAME=Omnivra AI Company OS      # sent as X-Title

# Groq (OpenAI-compatible + Whisper/Orpheus) - QA, SEO, Reel, STT, TTS
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
# Text-to-Speech (reel voiceover) via Groq's /audio/speech. Orpheus by default; if your
# account lacks Orpheus, switch to PlayAI: GROQ_TTS_MODEL=playai-tts GROQ_TTS_VOICE=Fritz-PlayAI
GROQ_TTS_MODEL=canopylabs/orpheus-v1-english
GROQ_TTS_VOICE=autumn               # Groq Orpheus voices: autumn, diana, hannah, austin, daniel, troy
GROQ_TTS_FORMAT=wav
# First time: accept the Orpheus model terms at
# https://console.groq.com/playground?model=canopylabs%2Forpheus-v1-english

# Hugging Face - Image Generation (black-forest-labs/FLUX.1-schnell via the hf-inference router).
# NOTE: api-inference.huggingface.co is retired — use the router endpoint below.
HUGGINGFACE_API_KEY=
HUGGINGFACE_INFERENCE_ENDPOINT=https://router.huggingface.co/hf-inference

# --- Social pipeline (cp-0016): media source + platform publishers ---
# All OPTIONAL. Unset -> the reel/post pipeline runs in stub mode (drafts + approval
# work fully offline; publishing is recorded as a stub instead of a real upload).
PEXELS_API_KEY=                     # stock B-roll for reels (Pexels Video API)
# reels -> YouTube upload (OAuth2; see docs/SOCIAL_PUBLISHING.md to obtain a refresh token)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
INSTAGRAM_ACCESS_TOKEN=             # reels -> Instagram (Graph API; Business/Creator acct)
FACEBOOK_PAGE_TOKEN=                # posts -> Facebook Page
LINKEDIN_ACCESS_TOKEN=              # posts -> LinkedIn
TWITTER_BEARER_TOKEN=               # posts -> Twitter / X

# --- Supabase Cloud (Postgres + pgvector + Storage + Realtime) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=                  # browser-safe; used by frontend, mirrored here for parity
SUPABASE_SERVICE_ROLE_KEY=          # SERVER ONLY. Never expose to the frontend.
SUPABASE_DB_PASSWORD=               # for direct asyncpg / langgraph postgres checkpointer (Phase 3)
SUPABASE_STORAGE_BUCKET=omnivra-artifacts
# Direct Postgres DSN (for langgraph-checkpoint-postgres in Phase 3)
SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# --- Redis / Upstash (queue + ephemeral run state) ---
REDIS_URL=redis://localhost:6379/0            # or rediss://default:[TOKEN]@[HOST].upstash.io:6379

# --- Orchestration safety ---
MAX_RECURSION=3                     # kill switch: recursion_count > MAX_RECURSION -> FAILED
PROVIDER_TIMEOUT_SECONDS=60
PROVIDER_MAX_RETRIES=5              # tenacity attempts on 429 / timeout / transient

# --- Security ---
API_SECRET_KEY=change-me-in-prod    # signs internal tokens / approval resume tokens
# A PUBLIC deployment (e.g. a Hugging Face Space) has no network gate — TURN AUTH ON so strangers
# can't drive your agents and burn your provider quota. Then log in with the admin creds below.
AUTH_ENABLED=false                  # set true in any public deployment
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-prod
SECURITY_HEADERS_ENABLED=true
RATE_LIMIT_ENABLED=false            # set true in public deployments
RATE_LIMIT_PER_MINUTE=240

# --- Deployment / performance ---
# CORS: in prod set this to your Vercel URL, e.g. https://omnivra.vercel.app
# The universal app-runner spawns venv/npm subprocesses + binds local ports. On a shared host
# (HF Space) the launched app's localhost port isn't reachable AND running generated code is a
# security/AUP risk -> DISABLE it there (Download-as-ZIP + run locally still works).
APP_RUNNER_ENABLED=true             # set false on a shared/public host
DASHBOARD_CACHE_TTL=2.0             # seconds; many polling clients share one rebuild. 0 = off
GZIP_MIN_SIZE=512                   # gzip responses larger than this many bytes
