# ===========================================================================
# Omnivra AI Company OS â€” ROOT .env.example
# ---------------------------------------------------------------------------
# This root file holds ONLY cross-cutting values used by repo-level scripts
# (scripts/dev.ps1, scripts/setup.ps1). The real, tier-specific secrets live in:
#
#   frontend/.env   (Vite â€” only VITE_* vars are exposed to the browser)
#   backend/.env    (FastAPI â€” provider API keys, DB service role, etc.)
#
# Copy each *.env.example to *.env and fill in. NEVER commit a real .env.
# ===========================================================================

# ---- Local dev ports (used by scripts to wire FE<->BE) ----
FRONTEND_PORT=5173
BACKEND_PORT=8000
BACKEND_HOST=127.0.0.1

# ---- Shared Supabase project reference (non-secret) ----
# Full Supabase config (keys) is split across frontend/.env and backend/.env.
SUPABASE_PROJECT_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_PROJECT_REF=YOUR-PROJECT-ref

# ---- Environment selector consumed by scripts ----
# one of: development | staging | production
APP_ENV=development

# ---- Convenience: where agent output is written (WORKSPACE RULE) ----
# Agents may ONLY write under this path. Do not point it at source dirs.
WORKSPACE_DIR=./workspace
